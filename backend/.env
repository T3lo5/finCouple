# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/fincouple
# Railway: copy from Railway dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/fincouple

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Used to salt password hashes — generate with: openssl rand -hex 32
PASSWORD_SALT=change_me_in_production_openssl_rand_hex_32

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Brevo Email Service ──────────────────────────────────────────────────────
# Get your API key at https://app.brevo.com (free tier: 300 emails/day)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=noreply@fincouple.com
