```gitignore
# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
coverage/
htmlcov/
*.out
*.exe
*.dll
*.so
*.a
*.obj

# OS generated files
.DS_Store
Thumbs.db

# Testing
.mypy_cache/
.pytest_cache/
.coverage

# Original rules preserved
*.log
```